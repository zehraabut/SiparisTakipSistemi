@model SiparisTakipSistemi.Models.Siparisler

@{
    ViewData["Title"] = "Kargo Düzenle";
    var kullanicilar = ViewBag.Kullanicilar as List<SiparisTakipSistemi.Models.Kullanicilar> ?? new List<SiparisTakipSistemi.Models.Kullanicilar>();
    var kargoFirmalari = ViewBag.KargoFirmalari as List<SiparisTakipSistemi.Models.KargoFirmalari> ?? new List<SiparisTakipSistemi.Models.KargoFirmalari>();
}

<div class="container mt-5 mb-5">
    <div class="card shadow p-4">
        <h4 class="mb-4 text-warning d-flex align-items-center">
            <i class="fas fa-shipping-fast me-2"></i> Kargo Bilgisi Güncelle
        </h4>

        <form asp-action="KargoDuzenle" method="post">
            <input type="hidden" name="SiparisID" value="@Model.SiparisID" />

           
<div class="row mb-3">
    <div class="col-md-6">
                    <label class="form-label" style="font-weight: 700; font-size: 1.1rem;">Kullanıcı:</label>

        <select name="KullaniciID" class="form-select" required>
                        @foreach (var k in kullanicilar)
                        {
                            if (k.KullaniciID == Model.KullaniciID)
                            {
                                <option value="@k.KullaniciID" selected>
                                    @k.KullaniciAdi (@k.Eposta)
                                </option>
                            }
                            else
                            {
                                <option value="@k.KullaniciID">
                                    @k.KullaniciAdi (@k.Eposta)
                                </option>
                            }
                        }

        </select>
    </div>

    <div class="col-md-6">
                    <label class="form-label" style="font-weight: 700; font-size: 1.1rem;">Kargo Firması:</label>
        <select name="KargoFirmaID" class="form-select" required>
                        @foreach (var firma in kargoFirmalari)
                        {
                            if (firma.KargoFirmaID == Model.Kargo.KargoFirmaID)
                            {
                                <option value="@firma.KargoFirmaID" selected>
                                    @firma.FirmaAdi
                                </option>
                            }
                            else
                            {
                                <option value="@firma.KargoFirmaID">
                                    @firma.FirmaAdi
                                </option>
                            }
                        }

        </select>
    </div>
</div>


            <div class="mb-3">
                <label class="form-label fw-bold">Takip Numarası</label>
                <input name="TakipNumarasi" class="form-control" value="@Model.Kargo.TakipNumarasi" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Durum</label>
                <input name="Durum" class="form-control" value="@Model.Kargo.Durum" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Konum</label>
                <input name="Konum" class="form-control" value="@Model.Kargo.Konum" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Tahmini Teslim Günü</label>
                <input name="TahminiTeslimGun" type="number" class="form-control" value="@Model.Kargo.TahminiTeslimGun" min="1" required />
            </div>

           
            <div class="row mt-4">
                <div class="col-md-3">
                    <button type="submit" class="btn btn-warning btn-sm w-100">Güncelle</button>
                </div>
                <div class="col-md-3">
                    <a asp-action="Kargolar" class="btn btn-secondary btn-sm w-100">İptal</a>
                </div>
            </div>
        </form>
    </div>
</div>
