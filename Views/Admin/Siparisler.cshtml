@model List<SiparisTakipSistemi.Models.Siparisler>

@{
    ViewData["Title"] = "Yönetim Paneli - Siparişler";
    var seciliKullaniciId = ViewBag.SeciliKullaniciId != null ? ViewBag.SeciliKullaniciId.ToString() : "";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary mb-0">
            <i class="fas fa-list-alt me-2 text-primary"></i> Sipariş Listesi
        </h2>

        <!-- Kullanıcı Filtreleme Dropdown -->
        <form method="get" asp-action="Siparisler" class="d-flex align-items-center">
            <label class="form-label" style="margin-right: 20px; font-weight: 700; font-size: 1.1rem;">Kullanıcı Seç:</label>

            <select name="kullaniciId" class="form-select me-2" style="width: 250px;" onchange="this.form.submit()">

                <option value="">-- Tüm Kullanıcılar --</option>
                @foreach (var kullanici in ViewBag.Kullanicilar)
                {
                    var selected = (ViewBag.SeciliKullaniciId != null && ViewBag.SeciliKullaniciId.ToString() == kullanici.KullaniciID.ToString()) ? "selected" : "";
                    <option value="@kullanici.KullaniciID" selected="@(selected == "selected")">
                        @kullanici.KullaniciAdi
                    </option>
                }

}

            </select>
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-circle me-1"></i> Bu kullanıcıya ait sipariş bulunmamaktadır.
        </div>
    }
    else
    {
        <!-- Siparişler Tablosu -->
        <table class="table table-bordered shadow-sm" style="background-color: #f8f9fa;">
            <thead style="background-color: #dee2e6;">
                <tr>
                    <th class="fw-bold text-dark">
                        <i class="fas fa-user me-1 text-info"></i> Kullanıcı
                    </th>
                    <th class="fw-bold text-dark">
                        <i class="fas fa-calendar-alt me-1 text-warning"></i> Sipariş Tarihi
                    </th>
                    <th class="fw-bold text-dark">
                        <i class="fas fa-truck me-1" style="color: saddlebrown;"></i> Kargo Firması
                    </th>
                    <th class="fw-bold text-dark">
                        <i class="fas fa-barcode me-1 text-secondary"></i> Takip Numarası
                    </th>
                    <th class="fw-bold text-dark">
                        <i class="fas fa-info-circle me-1" style="color: black;"></i> Durum
                    </th>
                    <th class="fw-bold text-dark">
                        <i class="fas fa-lira-sign me-1 text-success"></i> Toplam
                    </th>
                    <th class="fw-bold text-dark">
                        <i class="fas fa-tools me-1 text-secondary"></i> İşlem
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var siparis in Model)
                {
                    <tr>
                        <td>@siparis.Kullanici?.KullaniciAdi</td>
                        <td>@siparis.SiparisTarihi.ToShortDateString()</td>
                        <td>@siparis.Kargo?.KargoFirmasi?.FirmaAdi</td>
                        <td>@siparis.Kargo?.TakipNumarasi</td>
                        <td>@siparis.Kargo?.Durum</td>
                        <td>@siparis.ToplamTutar ₺</td>
                        <td>
                            <a class="btn btn-info btn-sm" asp-action="SiparisDetay" asp-route-id="@siparis.SiparisID">
                                <i class="fas fa-eye me-1"></i> Detay
                            </a>
                            <a class="btn btn-danger btn-sm" asp-action="SiparisiSil" asp-route-id="@siparis.SiparisID"
                               onclick="return confirm('Bu siparişi silmek istediğinize emin misiniz?');">
                                <i class="fas fa-trash-alt me-1"></i> Sil
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
