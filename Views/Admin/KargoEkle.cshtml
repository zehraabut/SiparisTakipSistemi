@model SiparisTakipSistemi.Models.KargoEkleViewModel

@{
    ViewData["Title"] = "Yeni Kargo Ekle";
    var kullanicilar = ViewBag.Kullanicilar as List<SiparisTakipSistemi.Models.Kullanicilar> ?? new List<SiparisTakipSistemi.Models.Kullanicilar>();
    var kargoFirmalari = ViewBag.KargoFirmalari as List<SiparisTakipSistemi.Models.KargoFirmalari> ?? new List<SiparisTakipSistemi.Models.KargoFirmalari>();
}

<div class="container mt-5 mb-5">
   
    <div class="card shadow p-4">
        
        <h3 class="text-primary mb-4">
            <i class="fas fa-truck me-2"></i> Yeni Kargo Ekle
        </h3>



        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <strong>Hata:</strong> Lütfen eksik veya hatalı alanları kontrol edin.
            </div>
        }

        <form asp-action="KargoEkle" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label" style="font-weight: 700; font-size: 1.1rem;">Kullanıcı:</label>
                    <select asp-for="KullaniciID" class="form-select" required>
                        <option value="">-- Seçiniz --</option>
                        @foreach (var k in kullanicilar)
                        {
                            <option value="@k.KullaniciID">@k.KullaniciAdi (@k.Eposta)</option>
                        }
                    </select>
                    <span asp-validation-for="KullaniciID" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label" style="font-weight: 700; font-size: 1.1rem;">Kargo Firması:</label>
                    <select asp-for="KargoFirmaID" class="form-select" required>
                        <option value="">-- Seçiniz --</option>
                        @foreach (var firma in kargoFirmalari)
                        {
                            <option value="@firma.KargoFirmaID">@firma.FirmaAdi</option>
                        }
                    </select>
                    <span asp-validation-for="KargoFirmaID" class="text-danger"></span>
                </div>
            </div>


            <div class="mb-3">
                <label asp-for="TakipNumarasi" class="form-label fw-bold"></label>
                <input asp-for="TakipNumarasi" class="form-control" />
                <span asp-validation-for="TakipNumarasi" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Durum" class="form-label fw-bold"></label>
                <input asp-for="Durum" class="form-control" />
                <span asp-validation-for="Durum" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Konum" class="form-label fw-bold"></label>
                <input asp-for="Konum" class="form-control" />
                <span asp-validation-for="Konum" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TahminiTeslimGun" class="form-label fw-bold"></label>
                <input asp-for="TahminiTeslimGun" type="number" min="1" class="form-control" />
                <span asp-validation-for="TahminiTeslimGun" class="text-danger"></span>
            </div>

            <hr />

            <h5 class="fw-bold text-dark mb-3">Sipariş Detayı</h5>

            <div class="mb-3">
                <label asp-for="UrunAdi" class="form-label fw-bold">Ürün Adı</label>
                <input asp-for="UrunAdi" class="form-control" required />
                <span asp-validation-for="UrunAdi" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Adet" class="form-label fw-bold">Adet</label>
                <input asp-for="Adet" type="number" min="1" class="form-control" required />
                <span asp-validation-for="Adet" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="BirimFiyat" class="form-label fw-bold">Birim Fiyat (₺)</label>
                <input asp-for="BirimFiyat" type="number" step="0.01" min="0" class="form-control" required />
                <span asp-validation-for="BirimFiyat" class="text-danger"></span>
            </div>

           
            <div class="row mt-4">
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary btn-sm w-100">Kargo Ekle</button>
                </div>
                <div class="col-md-3">
                    <a asp-action="Kargolar" class="btn btn-secondary btn-sm w-100">İptal</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
