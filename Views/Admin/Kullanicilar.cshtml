@model List<SiparisTakipSistemi.Models.Kullanicilar>

@{
    ViewData["Title"] = "Kullanıcılar";
}

<div class="container mt-5">
    <h2 class="text-primary mb-4">
        <i class="fas fa-users me-2"></i> Kayıtlı Kullanıcılar
    </h2>

    <table class="table table-bordered table-hover shadow-sm" style="background-color: #f8f9fa;">
        <thead style="background-color: #dee2e6;">
            <tr>
                <th class="fw-bold text-dark">
                    <i class="fas fa-hashtag me-1 text-secondary"></i> ID
                </th>
                <th class="fw-bold text-dark">
                    <i class="fas fa-user me-1 text-info"></i> Kullanıcı Adı
                </th>
                <th class="fw-bold text-dark">
                    <i class="fas fa-envelope me-1 text-primary"></i> E-posta
                </th>
                <th class="fw-bold text-dark">
                    <i class="fas fa-user-tag me-1 text-success"></i> Rol
                </th>
                <th class="fw-bold text-dark">
                    <i class="fas fa-cogs me-1 text-secondary"></i> İşlem
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var k in Model)
            {
                <tr>
                    <td>@k.KullaniciID</td>
                    <td>@k.KullaniciAdi</td>
                    <td>@k.Eposta</td>
                    <td>@k.Rol</td>
                    <td>
                        <a asp-action="KullaniciyiSil" asp-route-id="@k.KullaniciID" class="btn btn-danger btn-sm" onclick="return confirm('Bu kullanıcı silinsin mi?');">
                            <i class="fas fa-trash-alt me-1"></i> Sil
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
