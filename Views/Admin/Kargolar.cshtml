@model List<SiparisTakipSistemi.Models.Siparisler>

@{
    ViewData["Title"] = "Kargoları Yönet";
}

<div class="container mt-4">
    <h2 class="text-primary mb-3">
        <i class="fas fa-shipping-fast me-2"></i> Kargolar ve Siparişler
    </h2>

    <form method="get" asp-action="Kargolar" class="d-flex align-items-center">
        <label class="form-label" style="margin-right: 20px; font-weight: 700; font-size: 1.1rem;">Kullanıcı Seç:</label>
        <select name="kullaniciId" class="form-select me-2" style="width: 250px;" onchange="this.form.submit()">
            <option value="">-- Tüm Kullanıcılar --</option>
            @foreach (var kullanici in ViewBag.Kullanicilar)
            {
                if (ViewBag.SeciliKullaniciId != null && ViewBag.SeciliKullaniciId.ToString() == kullanici.KullaniciID.ToString())
                {
                    <option value="@kullanici.KullaniciID" selected>@kullanici.KullaniciAdi</option>
                }
                else
                {
                    <option value="@kullanici.KullaniciID">@kullanici.KullaniciAdi</option>
                }
            }

        </select>
    </form>


    <a asp-action="KargoEkle" class="btn btn-primary mb-4">
        <i class="fas fa-plus-circle me-1"></i> Yeni Kargo Ekle
    </a>

    <table class="table table-bordered table-hover shadow-sm" style="background-color: #f8f9fa;">
        <thead style="background-color: #dee2e6;">
            <tr>
                <th class="fw-bold text-dark">
                    <i class="fas fa-hashtag me-1 text-secondary"></i> Sipariş ID
                </th>
                <th class="fw-bold text-dark">
                    <i class="fas fa-user me-1 text-info"></i> Kullanıcı
                </th>
                <th class="fw-bold text-dark">
                    <i class="fas fa-truck me-1" style="color: saddlebrown;"></i> Kargo Firması
                </th>
                <th class="fw-bold text-dark">
                    <i class="fas fa-barcode me-1 text-dark"></i> Takip Numarası
                </th>
                <th class="fw-bold text-dark">
                    <i class="fas fa-info-circle me-1" style="color: black;"></i> Durum
                </th>
                <th class="fw-bold text-dark">
                    <i class="fas fa-map-marker-alt me-1 text-danger"></i> Konum
                </th>
                <th class="fw-bold text-dark">
                    <i class="fas fa-clock me-1 text-warning"></i> Tahmini Teslim Günü
                </th>
                <th class="fw-bold text-dark">
                    <i class="fas fa-cogs me-1 text-secondary"></i> İşlemler
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td>@s.SiparisID</td>
                    <td>@s.Kullanici?.KullaniciAdi</td>
                    <td>@s.Kargo?.KargoFirmasi?.FirmaAdi</td>
                    <td>@s.Kargo?.TakipNumarasi</td>
                    <td>@s.Kargo?.Durum</td>
                    <td>@s.Kargo?.Konum</td>
                    <td>@s.Kargo?.TahminiTeslimGun</td>
                    <td>
                        <a asp-action="KargoDuzenle" asp-route-id="@s.SiparisID" class="btn btn-info btn-sm">
                            <i class="fas fa-edit me-1"></i> Güncelle
                        </a>

                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
