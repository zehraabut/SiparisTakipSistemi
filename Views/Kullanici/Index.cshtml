@model List<SiparisTakipSistemi.Models.Siparisler>
@{
    ViewData["Title"] = "Siparişlerim";
}

<div class="container mt-4">
    <h2 class="mb-4">Hoş geldiniz, @ViewBag.KullaniciAdi</h2>

    <!-- Özet Bilgiler -->
    <div class="row mb-3">
        <div class="col-md-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <h6 class="text-primary">
                        <i class="fas fa-boxes"></i> Toplam Sipariş Sayısı
                    </h6>
                    <h5>@ViewBag.SiparisSayisi</h5>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <h6 class="text-success">
                        <i class="fas fa-coins me-1"></i> Toplam Harcama
                    </h6>
                    <h5>@ViewBag.ToplamTutar ₺</h5>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <h6 class="text-warning">
                        <i class="fas fa-calendar-check me-1"></i> Son Sipariş Tarihi
                    </h6>
                    <h5>@(ViewBag.SonSiparisTarihi?.ToShortDateString() ?? "-")</h5>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtre -->
    <form method="get" class="mb-3">
        <div class="form-row">
            <div class="col">
                <select name="kargoFirmasi" class="form-control">
                    <option value="">Tüm Kargo Firmaları</option>
                    <option value="Yurtiçi Kargo">Yurtiçi Kargo</option>
                    <option value="MNG Kargo">MNG Kargo</option>
                    <option value="Aras Kargo">Aras Kargo</option>
                </select>
            </div>
            <div class="col">
                <div class="form-check">
                    <input type="checkbox" name="son30Gun" class="form-check-input" value="true" id="son30Gun">
                    <label class="form-check-label" for="son30Gun">Son 30 Gündeki Siparişler</label>
                </div>
            </div>
            <div class="col">
                <button type="submit" class="btn btn-primary">Filtrele</button>
            </div>
        </div>
    </form>

    <!-- Sipariş Tablosu -->
    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-light">
            <h5 class="m-0 font-weight-bold text-primary">
                <i class="fas fa-list me-2"></i> Sipariş Listesi
            </h5>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <p>Henüz siparişiniz bulunmamaktadır.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered shadow-sm" style="background-color: #f8f9fa;">
                        <thead style="background-color: #dee2e6;">
                            <tr>
                                <th class="fw-bold text-dark">
                                    <i class="fas fa-calendar-day me-1 text-primary"></i> Sipariş Tarihi
                                </th>
                                <th class="fw-bold text-dark">
                                    <i class="fas fa-truck me-1" style="color: #8B4513;"></i> Kargo Firması
                                </th>
                                <th class="fw-bold text-dark">
                                    <i class="fas fa-barcode me-1 text-secondary"></i> Takip Numarası
                                </th>
                                <th class="fw-bold text-dark">
                                    <i class="fas fa-info-circle me-1 text-dark"></i> Durum
                                </th>
                                <th class="fw-bold text-dark">
                                    <i class="fas fa-coins me-1 text-success"></i> Toplam
                                </th>
                                <th class="fw-bold text-dark">
                                    <i class="fas fa-eye me-1 text-info"></i> Detay
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model)
                            {
                                <tr>
                                    <td>@s.SiparisTarihi.ToShortDateString()</td>
                                    <td>@s.Kargo?.KargoFirmasi?.FirmaAdi</td>
                                    <td>@s.Kargo?.TakipNumarasi</td>
                                    <td>@s.Kargo?.Durum</td>
                                    <td>@s.ToplamTutar ₺</td>
                                    <td>
                                        <a asp-action="SiparisDetay" asp-route-id="@s.SiparisID" class="btn btn-info btn-sm">
                                            <i class="fas fa-search me-1"></i> Detay
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div> 
